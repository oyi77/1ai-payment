{
  "name": "1ai-payment",
  "version": "0.1.0",
  "description": "Payment gateway aggregation microservice for 1ai-ecosystem",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "bun x tsc --noEmit",
    "lint": "bun x biome check src/",
    "lint:fix": "bun x biome check --apply src/"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@libsql/client": "^0.6.0",
    "hono": "^4.0.0",
    "nanoid": "^5.0.0",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0",
    "@biomejs/biome": "^1.8.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "license": "UNLICENSED",
  "private": true
}
