# ===========================================
# 1ai-payment Environment Configuration
# ===========================================
# Copy this to .env and fill in your credentials

# Server
PORT=3100
NODE_ENV=development
DATABASE_PATH=./data/payment.db
API_KEY=your-api-key-here

# Encryption key (64-char hex, 32 bytes) — generate with: openssl rand -hex 32
# WARNING: Rotating this key will corrupt existing encrypted gateway credentials
ENCRYPTION_KEY=f0bbe8000253a9997331287d3ebdadd3854720a049233b18a37dd401b61b4c6f

# Restrict CORS (set to your domain in production, e.g. https://app.example.com)
CORS_ORIGIN=*

# ===========================================
# MIDTRANS (Indonesia)
# ===========================================
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_ENVIRONMENT=sandbox

# ===========================================
# TRIPAY (Indonesia)
# ===========================================
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
TRIPAY_ENVIRONMENT=sandbox

# ===========================================
# DUITKU (Indonesia)
# ===========================================
DUITKU_API_KEY=
DUITKU_MERCHANT_CODE=
DUITKU_ENVIRONMENT=sandbox

# ===========================================
# NOWPAYMENTS (Crypto)
# ===========================================
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_ENVIRONMENT=sandbox

# ===========================================
# IPAYMU (Indonesia)
# ===========================================
IPAYMU_API_KEY=
IPAYMU_VA_KEY=
IPAYMU_ENVIRONMENT=sandbox

# ===========================================
# SCALEV (Indonesia) - Headless Commerce Platform
# ===========================================
SCALEV_STOREFRONT_API_KEY=
SCALEV_STORE_ID=
SCALEV_VARIANT_ID=
SCALEV_WEBHOOK_SECRET=
SCALEV_ENVIRONMENT=sandbox

# ===========================================
# XENDIT (Indonesia/SEA)
# ===========================================
XENDIT_API_KEY=
XENDIT_CALLBACK_TOKEN=
XENDIT_ENVIRONMENT=sandbox

# ===========================================
# TELEGRAM STARS (Global)
# ===========================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ===========================================
# TELEGRAM PAYMENTS (Global)
# ===========================================
TELEGRAM_PAYMENT_PROVIDER_TOKEN=

# ===========================================
# PAYPAL (Global)
# ===========================================
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_WEBHOOK_SECRET=
PAYPAL_ENVIRONMENT=sandbox

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
